@page "/apoyos/crear"
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@inject ICrudService<ApoyoProfesoral> ApoyoService
@inject NavigationManager Navigation

<h3>Nuevo Apoyo Profesoral</h3>

<EditForm Model="@apoyo" OnValidSubmit="GuardarApoyo">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="estudios" class="form-label">Estudios (ID)</label>
        <InputNumber id="estudios" class="form-control" @bind-Value="apoyo.Estudios" />
    </div>

    <div class="mb-3">
        <div class="form-check">
            <InputCheckbox id="conApoyo" class="form-check-input" @bind-Value="apoyo.ConApoyo" />
            <label for="conApoyo" class="form-check-label">¿Cuenta con apoyo?</label>
        </div>
    </div>

    <div class="mb-3">
        <label for="institucion" class="form-label">Institución</label>
        <InputText id="institucion" class="form-control" @bind-Value="apoyo.Institucion" />
    </div>

    <div class="mb-3">
        <label for="tipo" class="form-label">Tipo</label>
        <InputText id="tipo" class="form-control" @bind-Value="apoyo.Tipo" />
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="/apoyos" class="btn btn-secondary">Cancelar</a>
</EditForm>

@code {
    private ApoyoProfesoral apoyo = new ApoyoProfesoral();

    private async Task GuardarApoyo()
    {
        if (await ApoyoService.CreateAsync("ApoyoProfesoral", apoyo))
        {
            Navigation.NavigateTo("/apoyos");
        }
    }
}
