@page "/apoyos/editar/{id:int}"
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@inject ICrudService<ApoyoProfesoral> ApoyoService
@inject NavigationManager Navigation

<h3>Editar Apoyo Profesoral</h3>

@if (apoyo == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="@apoyo" OnValidSubmit="ActualizarApoyo">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <div class="form-check">
                <InputCheckbox id="conApoyo" class="form-check-input" @bind-Value="apoyo.ConApoyo" />
                <label for="conApoyo" class="form-check-label">¿Cuenta con apoyo?</label>
            </div>
        </div>

        <div class="mb-3">
            <label for="institucion" class="form-label">Institución</label>
            <InputText id="institucion" class="form-control" @bind-Value="apoyo.Institucion" />
        </div>

        <div class="mb-3">
            <label for="tipo" class="form-label">Tipo</label>
            <InputText id="tipo" class="form-control" @bind-Value="apoyo.Tipo" />
        </div>

        <button type="submit" class="btn btn-primary">Actualizar</button>
        <a href="/apoyos" class="btn btn-secondary">Cancelar</a>
    </EditForm>
}

@code {
    [Parameter]
    public int id { get; set; }

    private ApoyoProfesoral? apoyo;

    protected override async Task OnInitializedAsync()
    {
        apoyo = await ApoyoService.GetByIdAsync("ApoyoProfesoral", id);
    }

    private async Task ActualizarApoyo()
    {
        if (apoyo != null && await ApoyoService.UpdateAsync("ApoyoProfesoral", id, apoyo))
        {
            Navigation.NavigateTo("/apoyos");
        }
    }
}
