@page "/evaluaciones/crear"
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@inject ICrudService<EvaluacionDocente> EvaluacionService
@inject ICrudService<Docente> DocenteService
@inject NavigationManager Navigation

<h3>Nueva Evaluación Docente</h3>

<EditForm Model="@evaluacion" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Calificación</label>
        <InputNumber class="form-control" @bind-Value="evaluacion.Calificacion" />
    </div>

    <div class="mb-3">
        <label class="form-label">Semestre</label>
        <InputText class="form-control" @bind-Value="evaluacion.Semestre" />
    </div>

    <div class="mb-3">
        <label class="form-label">Docente</label>
        <InputSelect class="form-control" @bind-Value="evaluacion.DocenteCedula">
            <option value="0">Seleccione un docente...</option>
            @if (docentes != null)
            {
                foreach (var d in docentes)
                {
                    <option value="@d.Cedula">@d.Nombres @d.Apellidos</option>
                }
            }
        </InputSelect>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="/evaluaciones" class="btn btn-secondary">Cancelar</a>
</EditForm>

@code {
    private EvaluacionDocente evaluacion = new EvaluacionDocente();
    private List<Docente>? docentes;

    protected override async Task OnInitializedAsync()
    {
        docentes = await DocenteService.GetAllAsync("Docente");
    }

    private async Task Guardar()
    {
        if (evaluacion.DocenteCedula == 0) return;
        if (await EvaluacionService.CreateAsync("EvaluacionDocente", evaluacion))
        {
            Navigation.NavigateTo("/evaluaciones");
        }
    }
}
