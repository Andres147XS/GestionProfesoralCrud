@page "/docentes/editar/{id:int}"
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@inject ICrudService<Docente> DocenteService
@inject NavigationManager Navigation

<h3>Editar Docente</h3>

@if (docente == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="@docente" OnValidSubmit="ActualizarDocente">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Cédula</label>
                <InputNumber class="form-control" @bind-Value="docente.Cedula" disabled />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Nombres</label>
                <InputText class="form-control" @bind-Value="docente.Nombres" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Apellidos</label>
                <InputText class="form-control" @bind-Value="docente.Apellidos" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Correo</label>
                <InputText class="form-control" @bind-Value="docente.Correo" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Género</label>
                <InputText class="form-control" @bind-Value="docente.Genero" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Cargo</label>
                <InputText class="form-control" @bind-Value="docente.Cargo" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Fecha de Nacimiento</label>
                <InputDate class="form-control" @bind-Value="docente.FechaNacimiento" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Teléfono</label>
                <InputText class="form-control" @bind-Value="docente.Telefono" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">URL Cvlac</label>
            <InputText class="form-control" @bind-Value="docente.UrlCvlac" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Escalafón</label>
                <InputText class="form-control" @bind-Value="docente.Escalafon" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Nacionalidad</label>
                <InputText class="form-control" @bind-Value="docente.Nacionalidad" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Perfil</label>
            <InputTextArea class="form-control" @bind-Value="docente.Perfil" />
        </div>

        <button type="submit" class="btn btn-primary">Actualizar</button>
        <a href="/docentes" class="btn btn-secondary">Cancelar</a>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }
    private Docente? docente;

    protected override async Task OnInitializedAsync()
    {
        docente = await DocenteService.GetByIdAsync("Docente", Id);
    }

    private async Task ActualizarDocente()
    {
        if (docente != null)
        {
            if (await DocenteService.UpdateAsync("Docente", Id, docente))
            {
                Navigation.NavigateTo("/docentes");
            }
        }
    }
}
