@page "/"

<PageTitle>Inicio — Gestión Profesoral</PageTitle>

<AuthorizeView>
    <Authorized Context="authUser">
        <div class="container mt-4">
            <div class="card border-primary shadow-sm">
                <div class="card-body text-center py-5">
                    <h2 class="text-primary">
                        <span class="oi oi-home me-2"></span>
                        Bienvenido, <strong>@authUser.User.Identity?.Name</strong>
                    </h2>
                    <p class="lead text-muted mt-2">
                        Rol: <span class="badge bg-primary fs-6">
                            @authUser.User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value
                        </span>
                    </p>
                    <hr />
                    <p class="text-muted">Selecciona una opción del menú lateral para comenzar.</p>
                    <AuthorizeView Roles="Administrador" Context="adminCtx">
                        <Authorized>
                            <div class="alert alert-warning d-inline-block mt-2">
                                <span class="oi oi-shield me-2"></span>
                                Tienes acceso de <strong>Administrador</strong> — puedes gestionar usuarios y roles.
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="container mt-5">
            <div class="card shadow text-center py-5" style="max-width:500px; margin:auto;">
                <div class="card-body">
                    <h2 class="text-secondary">Sistema de Gestión Profesoral</h2>
                    <p class="text-muted mt-3">Debes iniciar sesión para acceder al sistema.</p>
                    <a href="/login" class="btn btn-primary btn-lg mt-2">
                        <span class="oi oi-account-login me-2"></span>Iniciar Sesión
                    </a>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
