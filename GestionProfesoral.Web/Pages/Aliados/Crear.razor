@page "/aliados/crear"
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@inject ICrudService<Aliado> AliadoService
@inject NavigationManager Navigation

<h3>Nuevo Aliado</h3>

<EditForm Model="@aliado" OnValidSubmit="GuardarAliado">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="nit" class="form-label">NIT</label>
        <InputNumber id="nit" class="form-control" @bind-Value="aliado.Nit" />
    </div>

    <div class="mb-3">
        <label for="razonSocial" class="form-label">Razón Social</label>
        <InputText id="razonSocial" class="form-control" @bind-Value="aliado.RazonSocial" />
    </div>

    <div class="mb-3">
        <label for="contacto" class="form-label">Nombre de Contacto</label>
        <InputText id="contacto" class="form-control" @bind-Value="aliado.NombreContacto" />
    </div>

    <div class="mb-3">
        <label for="correo" class="form-label">Correo</label>
        <InputText id="correo" class="form-control" @bind-Value="aliado.Correo" />
    </div>

    <div class="mb-3">
        <label for="telefono" class="form-label">Teléfono</label>
        <InputText id="telefono" class="form-control" @bind-Value="aliado.Telefono" />
    </div>

    <div class="mb-3">
        <label for="ciudad" class="form-label">Ciudad</label>
        <InputText id="ciudad" class="form-control" @bind-Value="aliado.Ciudad" />
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="/aliados" class="btn btn-secondary">Cancelar</a>
</EditForm>

@code {
    private Aliado aliado = new Aliado();

    private async Task GuardarAliado()
    {
        if (await AliadoService.CreateAsync("Aliado", aliado))
        {
            Navigation.NavigateTo("/aliados");
        }
    }
}
