@page "/docente-departamento"
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@inject ICrudService<DocenteDepartamento> DDService
@inject NavigationManager Navigation

<h3>Docente por Departamento</h3>

<div class="mb-3">
    <a href="/docente-departamento/crear" class="btn btn-primary">Nueva Asignación</a>
</div>

@if (asignaciones == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Docente</th>
                <th>Dpto ID</th>
                <th>Dedicación</th>
                <th>Modalidad</th>
                <th>Ingreso</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dd in asignaciones)
            {
                <tr>
                    <td>@(dd.Docente?.Nombres + " " + dd.Docente?.Apellidos)</td>
                    <td>@dd.DepartamentoId</td>
                    <td>@dd.Dedicacion</td>
                    <td>@dd.Modalidad</td>
                    <td>@dd.FechaIngreso?.ToShortDateString()</td>
                    <td>
                        <button class="btn btn-danger btn-sm" @onclick="() => Eliminar(dd.DocenteCedula, dd.DepartamentoId)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<DocenteDepartamento>? asignaciones;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        asignaciones = await DDService.GetAllAsync("DocenteDepartamento");
    }

    private async Task Eliminar(int cedula, int dptoId)
    {
        // En este caso el endpoint de borrado requiere ambos IDs
        if (await DDService.DeleteAsync($"DocenteDepartamento/{cedula}", dptoId))
        {
            await Cargar();
        }
    }
}
