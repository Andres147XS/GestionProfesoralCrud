@page "/docente-departamento/crear"
@attribute [Authorize(Roles = "Administrador,Docente")]
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@inject ICrudService<DocenteDepartamento> DDService
@inject ICrudService<Docente> DocenteService
@inject NavigationManager Navigation

<h3>Nueva Asignación Docente-Departamento</h3>

<EditForm Model="@dd" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Docente</label>
        <InputSelect class="form-control" @bind-Value="dd.DocenteCedula">
            <option value="0">Seleccione un docente...</option>
            @if (docentes != null)
            {
                foreach (var d in docentes)
                {
                    <option value="@d.Cedula">@d.Nombres @d.Apellidos</option>
                }
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label class="form-label">Departamento ID</label>
        <InputNumber class="form-control" @bind-Value="dd.DepartamentoId" />
    </div>

    <div class="mb-3">
        <label class="form-label">Dedicación</label>
        <InputText class="form-control" @bind-Value="dd.Dedicacion" />
    </div>

    <div class="mb-3">
        <label class="form-label">Modalidad</label>
        <InputText class="form-control" @bind-Value="dd.Modalidad" />
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Fecha Ingreso</label>
            <InputDate class="form-control" @bind-Value="dd.FechaIngreso" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Fecha Salida</label>
            <InputDate class="form-control" @bind-Value="dd.FechaSalida" />
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="/docente-departamento" class="btn btn-secondary">Cancelar</a>
</EditForm>

@code {
    private DocenteDepartamento dd = new DocenteDepartamento();
    private List<Docente>? docentes;

    protected override async Task OnInitializedAsync()
    {
        docentes = await DocenteService.GetAllAsync("Docente");
    }

    private async Task Guardar()
    {
        if (dd.DocenteCedula == 0 || dd.DepartamentoId == 0) return;
        if (await DDService.CreateAsync("DocenteDepartamento", dd))
        {
            Navigation.NavigateTo("/docente-departamento");
        }
    }
}
