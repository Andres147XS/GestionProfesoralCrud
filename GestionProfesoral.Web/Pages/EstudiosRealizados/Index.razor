@page "/estudios"
@attribute [Authorize]
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject ICrudService<EstudiosRealizados> EstudiosService
@inject NavigationManager Navigation

<h3>Estudios Realizados</h3>

<AuthorizeView Roles="Administrador,Docente">
    <Authorized>
        <div class="mb-3">
            <a href="/estudios/crear" class="btn btn-primary">Nuevo Estudio</a>
        </div>
    </Authorized>
</AuthorizeView>

@if (estudios == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Título</th>
                <th>Universidad</th>
                <th>Tipo</th>
                <th>Docente</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var est in estudios)
            {
                <tr>
                    <td>@est.Id</td>
                    <td>@est.Titulo</td>
                    <td>@est.Universidad</td>
                    <td>@est.Tipo</td>
                    <td>@(est.Docente?.Nombres + " " + est.Docente?.Apellidos)</td>
                    <td>
                        <AuthorizeView Roles="Administrador,Docente">
                            <Authorized>
                                <a href="/estudios/editar/@est.Id" class="btn btn-warning btn-sm">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => Eliminar(est.Id)">Eliminar</button>
                            </Authorized>
                            <NotAuthorized>
                                <span class="badge bg-secondary">Solo lectura</span>
                            </NotAuthorized>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<EstudiosRealizados>? estudios;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        estudios = await EstudiosService.GetAllAsync("EstudiosRealizados");
    }

    private async Task Eliminar(int id)
    {
        if (await EstudiosService.DeleteAsync("EstudiosRealizados", id))
        {
            await Cargar();
        }
    }
}
