@page "/estudios/crear"
@attribute [Authorize(Roles = "Administrador,Docente")]
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@inject ICrudService<EstudiosRealizados> EstudiosService
@inject ICrudService<Docente> DocenteService
@inject NavigationManager Navigation

<h3>Nuevo Estudio Realizado</h3>

<EditForm Model="@estudio" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Título</label>
        <InputText class="form-control" @bind-Value="estudio.Titulo" />
    </div>

    <div class="mb-3">
        <label class="form-label">Universidad</label>
        <InputText class="form-control" @bind-Value="estudio.Universidad" />
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Tipo</label>
            <InputText class="form-control" @bind-Value="estudio.Tipo" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Fecha</label>
            <InputDate class="form-control" @bind-Value="estudio.Fecha" />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Ciudad</label>
            <InputText class="form-control" @bind-Value="estudio.Ciudad" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">País</label>
            <InputText class="form-control" @bind-Value="estudio.Pais" />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Docente</label>
        <InputSelect class="form-control" @bind-Value="estudio.DocenteCedula">
            <option value="0">Seleccione un docente...</option>
            @if (docentes != null)
            {
                foreach (var d in docentes)
                {
                    <option value="@d.Cedula">@d.Nombres @d.Apellidos</option>
                }
            }
        </InputSelect>
    </div>

    <div class="mb-3 form-check">
        <InputCheckbox id="insAcreditada" class="form-check-input" @bind-Value="estudio.InsAcreditada" />
        <label class="form-check-label" for="insAcreditada">Institución Acreditada</label>
    </div>

    <div class="mb-3">
        <label class="form-label">Metodología</label>
        <InputText class="form-control" @bind-Value="estudio.Metodologia" />
    </div>

    <div class="mb-3">
        <label class="form-label">Perfil del Egresado</label>
        <InputTextArea class="form-control" @bind-Value="estudio.PerfilEgresado" />
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="/estudios" class="btn btn-secondary">Cancelar</a>
</EditForm>

@code {
    private EstudiosRealizados estudio = new EstudiosRealizados();
    private List<Docente>? docentes;

    protected override async Task OnInitializedAsync()
    {
        docentes = await DocenteService.GetAllAsync("Docente");
    }

    private async Task Guardar()
    {
        if (estudio.DocenteCedula == 0) return;
        if (await EstudiosService.CreateAsync("EstudiosRealizados", estudio))
        {
            Navigation.NavigateTo("/estudios");
        }
    }
}