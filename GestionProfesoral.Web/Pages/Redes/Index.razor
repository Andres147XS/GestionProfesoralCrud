@page "/redes"
@attribute [Authorize]
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject ICrudService<Red> RedService
@inject NavigationManager Navigation

<h3>Redes</h3>

<AuthorizeView Roles="Administrador,Docente">
    <Authorized>
        <div class="mb-3">
            <a href="/redes/crear" class="btn btn-primary">Nueva Red</a>
        </div>
    </Authorized>
</AuthorizeView>

@if (redes == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>URL</th>
                <th>País</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var red in redes)
            {
                <tr>
                    <td>@red.Id</td>
                    <td>@red.Nombre</td>
                    <td>@red.Url</td>
                    <td>@red.Pais</td>
                    <td>
                        <AuthorizeView Roles="Administrador,Docente">
                            <Authorized>
                                <a href="/redes/editar/@red.Id" class="btn btn-warning btn-sm">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => EliminarRed(red.Id)">Eliminar</button>
                            </Authorized>
                            <NotAuthorized>
                                <span class="badge bg-secondary">Solo lectura</span>
                            </NotAuthorized>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Red>? redes;

    protected override async Task OnInitializedAsync()
    {
        await CargarRedes();
    }

    private async Task CargarRedes()
    {
        redes = await RedService.GetAllAsync("Red");
    }

    private async Task EliminarRed(int id)
    {
        if (await RedService.DeleteAsync("Red", id))
        {
            await CargarRedes();
        }
    }
}
