@page "/redes/editar/{id:int}"
@attribute [Authorize(Roles = "Administrador,Docente")]
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@inject ICrudService<Red> RedService
@inject NavigationManager Navigation

<h3>Editar Red</h3>

@if (red == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="@red" OnValidSubmit="ActualizarRed">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="nombre" class="form-label">Nombre</label>
            <InputText id="nombre" class="form-control" @bind-Value="red.Nombre" />
        </div>

        <div class="mb-3">
            <label for="url" class="form-label">URL</label>
            <InputText id="url" class="form-control" @bind-Value="red.Url" />
        </div>

        <div class="mb-3">
            <label for="pais" class="form-label">País</label>
            <InputText id="pais" class="form-control" @bind-Value="red.Pais" />
        </div>

        <button type="submit" class="btn btn-primary">Actualizar</button>
        <a href="/redes" class="btn btn-secondary">Cancelar</a>
    </EditForm>
}

@code {
    [Parameter]
    public int id { get; set; }

    private Red? red;

    protected override async Task OnInitializedAsync()
    {
        red = await RedService.GetByIdAsync("Red", id);
    }

    private async Task ActualizarRed()
    {
        if (red != null && await RedService.UpdateAsync("Red", id, red))
        {
            Navigation.NavigateTo("/redes");
        }
    }
}
