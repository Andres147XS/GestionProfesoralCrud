@page "/experiencias"
@attribute [Authorize]
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject ICrudService<Experiencia> ExperienciaService
@inject NavigationManager Navigation

<h3>Experiencia</h3>

<AuthorizeView Roles="Administrador,Docente">
    <Authorized>
        <div class="mb-3">
            <a href="/experiencias/crear" class="btn btn-primary">Nueva Experiencia</a>
        </div>
    </Authorized>
</AuthorizeView>

@if (experiencias == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Cargo</th>
                <th>Institución</th>
                <th>Tipo</th>
                <th>Docente</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var exp in experiencias)
            {
                <tr>
                    <td>@exp.Id</td>
                    <td>@exp.NombreCargo</td>
                    <td>@exp.Institucion</td>
                    <td>@exp.Tipo</td>
                    <td>@(exp.Docente?.Nombres + " " + exp.Docente?.Apellidos)</td>
                    <td>
                        <AuthorizeView Roles="Administrador,Docente">
                            <Authorized>
                                <a href="/experiencias/editar/@exp.Id" class="btn btn-warning btn-sm">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => Eliminar(exp.Id)">Eliminar</button>
                            </Authorized>
                            <NotAuthorized>
                                <span class="badge bg-secondary">Solo lectura</span>
                            </NotAuthorized>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Experiencia>? experiencias;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        experiencias = await ExperienciaService.GetAllAsync("Experiencia");
    }

    private async Task Eliminar(int id)
    {
        if (await ExperienciaService.DeleteAsync("Experiencia", id))
        {
            await Cargar();
        }
    }
}
