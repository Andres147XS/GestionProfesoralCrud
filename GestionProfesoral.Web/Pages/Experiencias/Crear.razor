@page "/experiencias/crear"
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@inject ICrudService<Experiencia> ExperienciaService
@inject ICrudService<Docente> DocenteService
@inject NavigationManager Navigation

<h3>Nueva Experiencia</h3>

<EditForm Model="@experiencia" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Nombre del Cargo</label>
        <InputText class="form-control" @bind-Value="experiencia.NombreCargo" />
    </div>

    <div class="mb-3">
        <label class="form-label">Institución</label>
        <InputText class="form-control" @bind-Value="experiencia.Institucion" />
    </div>

    <div class="mb-3">
        <label class="form-label">Tipo</label>
        <InputText class="form-control" @bind-Value="experiencia.Tipo" />
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Fecha Inicio</label>
            <InputDate class="form-control" @bind-Value="experiencia.FechaInicio" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Fecha Fin</label>
            <InputDate class="form-control" @bind-Value="experiencia.FechaFin" />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Docente</label>
        <InputSelect class="form-control" @bind-Value="experiencia.DocenteCedula">
            <option value="0">Seleccione un docente...</option>
            @if (docentes != null)
            {
                foreach (var d in docentes)
                {
                    <option value="@d.Cedula">@d.Nombres @d.Apellidos</option>
                }
            }
        </InputSelect>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="/experiencias" class="btn btn-secondary">Cancelar</a>
</EditForm>

@code {
    private Experiencia experiencia = new Experiencia();
    private List<Docente>? docentes;

    protected override async Task OnInitializedAsync()
    {
        docentes = await DocenteService.GetAllAsync("Docente");
    }

    private async Task Guardar()
    {
        if (experiencia.DocenteCedula == 0) return;
        if (await ExperienciaService.CreateAsync("Experiencia", experiencia))
        {
            Navigation.NavigateTo("/experiencias");
        }
    }
}