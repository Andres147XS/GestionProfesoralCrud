@page "/becas/editar/{id:int}"
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@inject ICrudService<Beca> BecaService
@inject NavigationManager Navigation

<h3>Editar Beca</h3>

@if (beca == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="@beca" OnValidSubmit="ActualizarBeca">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="tipo" class="form-label">Tipo</label>
            <InputText id="tipo" class="form-control" @bind-Value="beca.Tipo" />
        </div>

        <div class="mb-3">
            <label for="institucion" class="form-label">Institución</label>
            <InputText id="institucion" class="form-control" @bind-Value="beca.Institucion" />
        </div>

        <div class="mb-3">
            <label for="inicio" class="form-label">Fecha Inicio</label>
            <InputDate id="inicio" class="form-control" @bind-Value="beca.FechaInicio" />
        </div>

        <div class="mb-3">
            <label for="fin" class="form-label">Fecha Fin</label>
            <InputDate id="fin" class="form-control" @bind-Value="beca.FechaFin" />
        </div>

        <button type="submit" class="btn btn-primary">Actualizar</button>
        <a href="/becas" class="btn btn-secondary">Cancelar</a>
    </EditForm>
}

@code {
    [Parameter]
    public int id { get; set; }

    private Beca? beca;

    protected override async Task OnInitializedAsync()
    {
        beca = await BecaService.GetByIdAsync("Beca", id);
    }

    private async Task ActualizarBeca()
    {
        if (beca != null && await BecaService.UpdateAsync("Beca", id, beca))
        {
            Navigation.NavigateTo("/becas");
        }
    }
}
