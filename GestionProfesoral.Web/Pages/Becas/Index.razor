@page "/becas"
@attribute [Authorize]
@using GestionProfesoral.Shared.Models
@using GestionProfesoral.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject ICrudService<Beca> BecaService
@inject NavigationManager Navigation

<h3>Becas</h3>

<AuthorizeView Roles="Administrador,Docente">
    <Authorized>
        <div class="mb-3">
            <a href="/becas/crear" class="btn btn-primary">Nueva Beca</a>
        </div>
    </Authorized>
</AuthorizeView>

@if (becas == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Estudios</th>
                <th>Tipo</th>
                <th>Institución</th>
                <th>Fecha Inicio</th>
                <th>Fecha Fin</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var beca in becas)
            {
                <tr>
                    <td>@beca.Estudios</td>
                    <td>@beca.Tipo</td>
                    <td>@beca.Institucion</td>
                    <td>@beca.FechaInicio.ToShortDateString()</td>
                    <td>@beca.FechaFin.ToShortDateString()</td>
                    <td>
                        <AuthorizeView Roles="Administrador,Docente">
                            <Authorized>
                                <a href="/becas/editar/@beca.Estudios" class="btn btn-warning btn-sm">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => EliminarBeca(beca.Estudios)">Eliminar</button>
                            </Authorized>
                            <NotAuthorized>
                                <span class="badge bg-secondary">Solo lectura</span>
                            </NotAuthorized>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Beca>? becas;

    protected override async Task OnInitializedAsync()
    {
        await CargarBecas();
    }

    private async Task CargarBecas()
    {
        becas = await BecaService.GetAllAsync("Beca");
    }

    private async Task EliminarBeca(int id)
    {
        if (await BecaService.DeleteAsync("Beca", id))
        {
            await CargarBecas();
        }
    }
}
