@page "/usuarios"
@attribute [Authorize(Roles = "Administrador")]
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation

<PageTitle>Gestión de Usuarios</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><span class="oi oi-people me-2"></span>Usuarios del Sistema</h3>
        <a href="/usuarios/crear" class="btn btn-success">
            <span class="oi oi-plus me-1"></span> Nuevo Usuario
        </a>
    </div>

    @if (!string.IsNullOrEmpty(mensajeExito))
    {
        <div class="alert alert-success alert-dismissible">
            <span class="oi oi-check me-2"></span>@mensajeExito
            <button type="button" class="btn-close" @onclick="() => mensajeExito = string.Empty"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="alert alert-danger alert-dismissible">
            <span class="oi oi-warning me-2"></span>@mensajeError
            <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
        </div>
    }

    @if (cargando)
    {
        <div class="text-center mt-4">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2">Cargando usuarios...</p>
        </div>
    }
    else if (usuarios == null || !usuarios.Any())
    {
        <div class="alert alert-info">No hay usuarios registrados.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Usuario</th>
                        <th>Correo</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in usuarios)
                    {
                        <tr>
                            <td>@u.Id</td>
                            <td><strong>@u.NombreUsuario</strong></td>
                            <td>@u.Correo</td>
                            <td>
                                <!-- Cambio de rol inline directamente en la tabla -->
                                <select class="form-select form-select-sm" style="min-width:140px;"
                                        value="@u.RolId"
                                        @onchange="e => CambiarRol(u, int.Parse(e.Value!.ToString()!))">
                                    @foreach (var r in roles)
                                    {
                                        <option value="@r.Id" selected="@(r.Id == u.RolId)">@r.Nombre</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox"
                                           checked="@u.Activo"
                                           @onchange="e => CambiarEstado(u, (bool)e.Value!)" />
                                    <label class="form-check-label">
                                        @(u.Activo ? "Activo" : "Inactivo")
                                    </label>
                                </div>
                            </td>
                            <td class="text-center">
                                <a href="/usuarios/editar/@u.Id" class="btn btn-sm btn-warning me-1" title="Editar">
                                    <span class="oi oi-pencil"></span>
                                </a>
                                <button class="btn btn-sm btn-danger" title="Eliminar"
                                        @onclick="() => ConfirmarEliminar(u)">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="text-muted small">
            <span class="oi oi-info me-1"></span>
            Puedes cambiar el rol y el estado de cada usuario directamente desde la tabla.
        </p>
    }
</div>

<!-- Modal confirmación eliminar -->
@if (mostrarConfirmacion)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar Eliminación</h5>
                </div>
                <div class="modal-body">
                    ¿Está seguro de eliminar al usuario <strong>@usuarioAEliminar?.NombreUsuario</strong>?
                    Esta acción no se puede deshacer.
                    @if (!string.IsNullOrEmpty(errorEliminar))
                    {
                        <div class="alert alert-danger mt-2">@errorEliminar</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => mostrarConfirmacion = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="EliminarUsuario">Sí, eliminar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<UsuarioDto>? usuarios;
    private List<Rol> roles = new();
    private bool cargando = true;
    private bool mostrarConfirmacion = false;
    private UsuarioDto? usuarioAEliminar;
    private string errorEliminar = string.Empty;
    private string mensajeExito = string.Empty;
    private string mensajeError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await ConfigurarHttp();
        await CargarDatos();
    }

    private async Task ConfigurarHttp()
    {
        try
        {
            var token = await LocalStorage.GetItemAsStringAsync("authToken");
            if (!string.IsNullOrWhiteSpace(token))
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
        catch { }
    }

    private async Task CargarDatos()
    {
        cargando = true;
        try
        {
            var rolesResp = await Http.GetFromJsonAsync<List<Rol>>("api/Rol");
            roles = rolesResp ?? new();
            var usuariosResp = await Http.GetFromJsonAsync<List<UsuarioDto>>("api/Usuario");
            usuarios = usuariosResp ?? new();
        }
        catch
        {
            mensajeError = "Error al cargar los datos. Verifique la conexión con la API.";
        }
        cargando = false;
    }

    private async Task CambiarRol(UsuarioDto usuario, int nuevoRolId)
    {
        if (usuario.RolId == nuevoRolId) return;
        mensajeExito = string.Empty;
        mensajeError = string.Empty;

        var dto = new UsuarioUpdateDto { RolId = nuevoRolId };
        try
        {
            var resp = await Http.PutAsJsonAsync($"api/Usuario/{usuario.Id}", dto);
            if (resp.IsSuccessStatusCode)
            {
                usuario.RolId = nuevoRolId;
                usuario.RolNombre = roles.FirstOrDefault(r => r.Id == nuevoRolId)?.Nombre ?? "";
                mensajeExito = $"Rol de '{usuario.NombreUsuario}' actualizado correctamente.";
            }
            else
            {
                mensajeError = "No se pudo cambiar el rol. Intente nuevamente.";
            }
        }
        catch { mensajeError = "Error de conexión al cambiar el rol."; }
    }

    private async Task CambiarEstado(UsuarioDto usuario, bool nuevoEstado)
    {
        mensajeExito = string.Empty;
        mensajeError = string.Empty;

        var dto = new UsuarioUpdateDto { Activo = nuevoEstado };
        try
        {
            var resp = await Http.PutAsJsonAsync($"api/Usuario/{usuario.Id}", dto);
            if (resp.IsSuccessStatusCode)
            {
                usuario.Activo = nuevoEstado;
                mensajeExito = $"Estado de '{usuario.NombreUsuario}' actualizado.";
            }
            else
            {
                mensajeError = "No se pudo cambiar el estado. Puede que sea el único administrador activo.";
            }
        }
        catch { mensajeError = "Error de conexión al cambiar el estado."; }
    }

    private void ConfirmarEliminar(UsuarioDto u)
    {
        usuarioAEliminar = u;
        errorEliminar = string.Empty;
        mostrarConfirmacion = true;
    }

    private async Task EliminarUsuario()
    {
        if (usuarioAEliminar == null) return;
        try
        {
            var resp = await Http.DeleteAsync($"api/Usuario/{usuarioAEliminar.Id}");
            if (resp.IsSuccessStatusCode)
            {
                mostrarConfirmacion = false;
                mensajeExito = $"Usuario '{usuarioAEliminar.NombreUsuario}' eliminado.";
                await CargarDatos();
            }
            else
            {
                errorEliminar = "No se puede eliminar. Es posible que sea el único administrador activo.";
            }
        }
        catch { errorEliminar = "Error de conexión al eliminar."; }
    }
}
