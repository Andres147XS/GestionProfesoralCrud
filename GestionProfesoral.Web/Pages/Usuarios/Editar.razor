@page "/usuarios/editar/{Id:int}"
@attribute [Authorize(Roles = "Administrador")]
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation

<PageTitle>Editar Usuario</PageTitle>

<div class="container" style="max-width:600px;">
    <div class="d-flex align-items-center mb-3 gap-2">
        <a href="/usuarios" class="btn btn-sm btn-outline-secondary">
            <span class="oi oi-arrow-left"></span>
        </a>
        <h3 class="mb-0"><span class="oi oi-pencil me-2"></span>Editar Usuario</h3>
    </div>

    @if (cargando)
    {
        <div class="text-center mt-4"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(error))   { <div class="alert alert-danger">@error</div> }
        @if (!string.IsNullOrEmpty(exito))   { <div class="alert alert-success">@exito</div> }

        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <strong>@nombreUsuarioOriginal</strong>
                <span class="badge bg-primary ms-2">@rolNombreOriginal</span>
            </div>
            <div class="card-body">

                <!-- Sección: Cambio de Rol -->
                <h6 class="text-uppercase text-muted mb-3" style="font-size:0.75rem; letter-spacing:1px;">
                    Control de Acceso / Rol
                </h6>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Rol del usuario</label>
                    <select class="form-select" @bind="rolIdSeleccionado">
                        @foreach (var r in roles)
                        {
                            <option value="@r.Id">@r.Nombre</option>
                        }
                    </select>
                    @if (roles.Any())
                    {
                        var rolInfo = roles.FirstOrDefault(r => r.Id == rolIdSeleccionado);
                        if (rolInfo?.Descripcion != null)
                        {
                            <small class="text-muted">@rolInfo.Descripcion</small>
                        }
                    }
                </div>
                <div class="mb-4 form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="chkActivo"
                           @bind="activoSeleccionado" />
                    <label class="form-check-label fw-semibold" for="chkActivo">
                        @(activoSeleccionado ? "Usuario Activo" : "Usuario Inactivo")
                    </label>
                </div>

                <hr />

                <!-- Sección: Datos personales -->
                <h6 class="text-uppercase text-muted mb-3" style="font-size:0.75rem; letter-spacing:1px;">
                    Datos del usuario
                </h6>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nombre de usuario</label>
                    <input class="form-control" @bind="nuevoNombreUsuario" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Correo electrónico</label>
                    <input type="email" class="form-control" @bind="nuevoCorreo" />
                </div>

                <hr />

                <!-- Sección: Cambio de contraseña -->
                <h6 class="text-uppercase text-muted mb-3" style="font-size:0.75rem; letter-spacing:1px;">
                    Cambiar contraseña <small class="text-muted">(opcional)</small>
                </h6>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nueva contraseña <small class="text-muted">(mín. 6 caracteres)</small></label>
                    <input type="password" class="form-control" @bind="nuevaPassword"
                           placeholder="Dejar vacío para no cambiar" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Confirmar nueva contraseña</label>
                    <input type="password" class="form-control" @bind="confirmarPassword"
                           placeholder="Repite la nueva contraseña" />
                </div>
                @if (!string.IsNullOrEmpty(errorPassword))
                {
                    <div class="alert alert-warning py-2 small">@errorPassword</div>
                }
            </div>
            <div class="card-footer d-flex gap-2">
                <button class="btn btn-warning" @onclick="Guardar" disabled="@guardando">
                    @if (guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <span class="oi oi-check me-1"></span>Guardar cambios
                </button>
                <a href="/usuarios" class="btn btn-secondary">Cancelar</a>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private List<Rol> roles = new();
    private int rolIdSeleccionado;
    private bool activoSeleccionado = true;
    private string nuevoNombreUsuario = string.Empty;
    private string nuevoCorreo = string.Empty;
    private string nuevaPassword = string.Empty;
    private string confirmarPassword = string.Empty;
    private string nombreUsuarioOriginal = string.Empty;
    private string rolNombreOriginal = string.Empty;
    private string error = string.Empty;
    private string exito = string.Empty;
    private string errorPassword = string.Empty;
    private bool cargando = true;
    private bool guardando = false;

    protected override async Task OnInitializedAsync()
    {
        await ConfigurarHttp();
        await CargarDatos();
    }

    private async Task ConfigurarHttp()
    {
        try
        {
            var token = await LocalStorage.GetItemAsStringAsync("authToken");
            if (!string.IsNullOrWhiteSpace(token))
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
        catch { }
    }

    private async Task CargarDatos()
    {
        try
        {
            var rolesResp = await Http.GetFromJsonAsync<List<Rol>>("api/Rol");
            roles = rolesResp ?? new();

            var usuario = await Http.GetFromJsonAsync<UsuarioDto>($"api/Usuario/{Id}");
            if (usuario == null) { Navigation.NavigateTo("/usuarios"); return; }

            nuevoNombreUsuario = usuario.NombreUsuario;
            nuevoCorreo = usuario.Correo;
            rolIdSeleccionado = usuario.RolId;
            activoSeleccionado = usuario.Activo;
            nombreUsuarioOriginal = usuario.NombreUsuario;
            rolNombreOriginal = usuario.RolNombre;
        }
        catch
        {
            Navigation.NavigateTo("/usuarios");
            return;
        }
        cargando = false;
    }

    private async Task Guardar()
    {
        error = string.Empty;
        exito = string.Empty;
        errorPassword = string.Empty;

        // Validar contraseña si se ingresó
        if (!string.IsNullOrWhiteSpace(nuevaPassword))
        {
            if (nuevaPassword.Length < 6)
            {
                errorPassword = "La contraseña debe tener al menos 6 caracteres.";
                return;
            }
            if (nuevaPassword != confirmarPassword)
            {
                errorPassword = "Las contraseñas no coinciden.";
                return;
            }
        }

        if (string.IsNullOrWhiteSpace(nuevoNombreUsuario))
        {
            error = "El nombre de usuario es obligatorio.";
            return;
        }

        guardando = true;

        var dto = new UsuarioUpdateDto
        {
            NombreUsuario = nuevoNombreUsuario.Trim(),
            Correo = nuevoCorreo.Trim(),
            RolId = rolIdSeleccionado,
            Activo = activoSeleccionado,
            Password = string.IsNullOrWhiteSpace(nuevaPassword) ? null : nuevaPassword
        };

        try
        {
            var resp = await Http.PutAsJsonAsync($"api/Usuario/{Id}", dto);
            if (resp.IsSuccessStatusCode)
            {
                exito = "Usuario actualizado correctamente.";
                nombreUsuarioOriginal = nuevoNombreUsuario;
                rolNombreOriginal = roles.FirstOrDefault(r => r.Id == rolIdSeleccionado)?.Nombre ?? "";
                nuevaPassword = string.Empty;
                confirmarPassword = string.Empty;
            }
            else
            {
                error = "No se pudo actualizar. El nombre de usuario puede estar en uso.";
            }
        }
        catch { error = "Error de conexión al guardar."; }

        guardando = false;
    }
}
