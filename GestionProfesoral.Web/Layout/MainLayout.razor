@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>
    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            <AuthorizeView Context="topBarAuth">
                <Authorized>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small">
                            <span class="oi oi-person me-1"></span>
                            <strong>@topBarAuth.User.Identity?.Name</strong>
                            &nbsp;|&nbsp;
                            <span class="badge bg-secondary">
                                @topBarAuth.User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value
                            </span>
                        </span>
                        <button class="btn btn-sm btn-outline-danger" @onclick="CerrarSesion">
                            <span class="oi oi-account-logout me-1"></span>Salir
                        </button>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn btn-sm btn-outline-primary">
                        <span class="oi oi-account-login me-1"></span>Iniciar Sesión
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task CerrarSesion()
    {
        await AuthService.LogoutAsync();
        // forceLoad: true para limpiar completamente el estado en memoria
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
